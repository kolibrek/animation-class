---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
---

<BaseLayout title="Animated Objects - Kevin Clemons">
  <main class="h-screen grid place-items-center content-center gap-16">
    <header class="grid place-items-center gap-8">
      <NavBar/>
      <h1 class="text-4xl text-lime">Animated Objects</h1>
    </header>
    <section class="grid position-relative place-items-center sm:grid-cols-[repeat(3,1fr)] gap-16">
      <div class="animated-icon bg-rose" id="icon-1"></div>
      <div class="animated-icon" id="icon-2"></div>
      <div class="perspective-300">
        <div class="animated-icon" id="icon-3">
          <div></div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .animated-icon {
    width: 128px;
    height: 128px;
  }

  #icon-1 {
    animation: spin 20s linear infinite, morph 5s ease infinite alternate;
  }

  #icon-2 {
    position: relative;
    border: 4px solid transparent;
    border-radius: 100%;
    background-color: #fff1;
    animation: hue 10s linear infinite, shake 5s ease infinite alternate-reverse;

    &::before {
      content: "";
      position: absolute;
      inset: 50% 0% 0% 0%;
      border-bottom-right-radius: 64px;
      border-bottom-left-radius: 64px;
      background-color: #0f0a;
      filter: drop-shadow(0 -10px 40px #0f0);
    }

    &::after {
      content: "";
      position: absolute;
      inset: 40% 0% 40% 0%;
      border-radius: 100%;
      background-color: #0f0;
    }
  }

  #icon-3 {
    --diameter: 96px;
    --radius: calc(var(--diameter) / 2);
    position: relative;
    transform-style: preserve-3d;
    transform-origin: 50% 50%;
    width: var(--diameter);
    height: var(--diameter);
    /* background-color: hsla(208, 100%, 50%, 0.533); */
    animation: turnY 4s linear infinite;

    &::before {
      content: "";
      position: absolute;
      width: 100%;
      height: 100%;
      background-color: hsla(238, 100%, 50%, 0.533);
      transform: translateZ(calc(var(--radius) * -1));
    }

    &::after {
      content: "";
      position: absolute;
      width: 100%;
      height: 100%;
      background-color: hsla(98, 100%, 50%, 0.533);
      transform: translateZ(var(--radius));
    }
    div {
      transform-style: preserve-3d;
      position: absolute;
      width: 100%;
      height: 100%;
      background-color: hsla(198, 100%, 50%, 0.533);
      transform: rotateX(90deg) translateZ(var(--radius));

      &::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        background-color: hsla(158, 100%, 50%, 0.533);
        transform: translateZ(calc(var(--diameter) * -1));
      }
      &::after {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        background-color: hsla(298, 100%, 50%, 0.533);
        transform: rotateY(90deg) translateZ(var(--radius)) translateX(var(--radius));
      }
    }
  }

  @keyframes shake {
    0% { transform: rotate(10deg); }
    50% { transform: rotate(-10deg); }
    100% { transform: rotate(0deg); }
  }

  @keyframes hue {
    to { filter: hue-rotate(1turn); }
  }

  @keyframes spin {
    to { transform: rotate(1turn); }
  }

  @keyframes turnY {
    to { transform: rotate3d(0,1,1, 1turn); }
  }

  @keyframes rotateX {
    from { transform: rotate3d(0, 1, 0, 0deg)}
    to { transform: rotate3d(0, 1, 0, 360deg); }
  }

  @keyframes morph {
    0% { border-radius: 40% 60% 60% 40% / 70% 30% 70% 30%; }
    50% { border-radius: 50% 50% 77% 23% / 76% 52% 48% 24%; }
    100% { border-radius: 40% 90%; }
  }
</style>